generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
  PASSWORD_RESET_REQUIRED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_NOTICE
  TERMINATED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  CONSULTANT
}

enum AttendanceStatus {
  PRESENT
  LATE
  HALF_DAY
  ABSENT
}

enum LeaveRequestStatus {
  PENDING_TEAM_LEAD
  PENDING_HR
  APPROVED
  REJECTED
  CANCELLED
}

enum JobStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
  CLOSED
}

enum ApplicationStage {
  APPLIED
  SCREENING
  INTERVIEW_SCHEDULED
  TECHNICAL_ROUND
  HR_ROUND
  SELECTED
  REJECTED
  OFFER_SENT
  JOINED
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum StorageProvider {
  CLOUDINARY
  S3
}

model User {
  id                  String       @id @default(uuid()) @db.Uuid
  userId              String       @unique @db.VarChar(64)
  passwordHash        String
  status              UserStatus   @default(PASSWORD_RESET_REQUIRED)
  forcePasswordReset  Boolean      @default(true)
  failedLoginAttempts Int          @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  employeeId          String?      @unique @db.Uuid
  employee            Employee?    @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  roles               UserRole[]
  sessions            AuthSession[]
  passwordResets      PasswordResetToken[]
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  deletedAt           DateTime?

  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique @db.VarChar(80)
  name        String           @db.VarChar(120)
  description String?
  hierarchyLevel Int           @default(100)
  isSystem    Boolean          @default(false)
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique @db.VarChar(120)
  resource    String           @db.VarChar(80)
  action      String           @db.VarChar(80)
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  @@index([resource, action])
  @@index([deletedAt])
  @@map("permissions")
}

model UserRole {
  userId    String   @db.Uuid
  roleId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  familyId         String    @db.Uuid
  replacedById     String?   @db.Uuid
  ipAddress        String?   @db.VarChar(80)
  userAgent        String?
  deviceInfo       Json?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Employee {
  id                 String       @id @default(uuid()) @db.Uuid
  employeeId         String       @unique @db.VarChar(64)
  firstName          String       @db.VarChar(120)
  lastName           String       @db.VarChar(120)
  email              String       @unique @db.VarChar(180)
  phone              String?      @db.VarChar(40)
  designation        String       @db.VarChar(140)
  department         String       @db.VarChar(140)
  joiningDate        DateTime
  employmentType     EmploymentType
  reportingManagerId String?      @db.Uuid
  reportingManager   Employee?    @relation("ReportingManager", fields: [reportingManagerId], references: [id], onDelete: SetNull)
  directReports      Employee[]   @relation("ReportingManager")
  status             EmployeeStatus @default(ACTIVE)
  profilePhoto       String?
  emergencyContact   Json?
  address            Json?
  user               User?
  leaveBalances      LeaveBalance[]
  leaveRequests      LeaveRequest[] @relation("LeaveRequester")
  approvals          LeaveApproval[] @relation("LeaveApprover")
  attendanceRecords  AttendanceRecord[]
  interviewAssignments Interview[] @relation("InterviewInterviewer")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?

  @@index([department])
  @@index([status])
  @@index([reportingManagerId])
  @@index([deletedAt])
  @@map("employees")
}

model AttendanceSetting {
  id             String   @id @default(uuid()) @db.Uuid
  officeStart    String   @db.VarChar(8)
  officeEnd      String   @db.VarChar(8)
  graceMinutes   Int      @default(10)
  workingDays    Json
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  @@index([isActive])
  @@map("attendance_settings")
}

model OfficeLocation {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(120)
  latitude        Decimal  @db.Decimal(10, 7)
  longitude       Decimal  @db.Decimal(10, 7)
  allowedRadiusM  Int
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([isActive])
  @@map("office_locations")
}

model AttendanceRecord {
  id             String           @id @default(uuid()) @db.Uuid
  employeeId     String           @db.Uuid
  employee       Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  attendanceDate DateTime
  checkInAt      DateTime?
  checkOutAt     DateTime?
  workMinutes    Int              @default(0)
  breakMinutes   Int              @default(0)
  status         AttendanceStatus  @default(ABSENT)
  checkInMeta    Json?
  checkOutMeta   Json?
  breaks         AttendanceBreak[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  @@unique([employeeId, attendanceDate])
  @@index([attendanceDate])
  @@index([status])
  @@map("attendance_records")
}

model AttendanceBreak {
  id                 String           @id @default(uuid()) @db.Uuid
  attendanceRecordId String           @db.Uuid
  attendanceRecord   AttendanceRecord @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)
  startedAt          DateTime
  endedAt            DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([attendanceRecordId])
  @@map("attendance_breaks")
}

model LeaveType {
  id          String         @id @default(uuid()) @db.Uuid
  name        String         @db.VarChar(120)
  code        String         @unique @db.VarChar(40)
  annualQuota Decimal        @db.Decimal(6, 2)
  isPaid      Boolean        @default(true)
  isActive    Boolean        @default(true)
  balances    LeaveBalance[]
  requests    LeaveRequest[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  @@index([isActive])
  @@map("leave_types")
}

model LeaveBalance {
  id           String    @id @default(uuid()) @db.Uuid
  employeeId   String    @db.Uuid
  leaveTypeId  String    @db.Uuid
  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType    LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  year         Int
  allocated    Decimal   @db.Decimal(6, 2)
  used         Decimal   @default(0) @db.Decimal(6, 2)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([employeeId, leaveTypeId, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id          String             @id @default(uuid()) @db.Uuid
  employeeId  String             @db.Uuid
  leaveTypeId String             @db.Uuid
  employee    Employee           @relation("LeaveRequester", fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType   LeaveType          @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  startDate   DateTime
  endDate     DateTime
  days        Decimal            @db.Decimal(6, 2)
  reason      String?
  status      LeaveRequestStatus @default(PENDING_TEAM_LEAD)
  approvals   LeaveApproval[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?

  @@index([employeeId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

model LeaveApproval {
  id             String       @id @default(uuid()) @db.Uuid
  leaveRequestId String       @db.Uuid
  approverId     String       @db.Uuid
  approver       Employee     @relation("LeaveApprover", fields: [approverId], references: [id], onDelete: Restrict)
  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  level          Int
  decision       String       @db.VarChar(40)
  remarks        String?
  decidedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([leaveRequestId])
  @@index([approverId])
  @@map("leave_approvals")
}

model JobPosting {
  id             String           @id @default(uuid()) @db.Uuid
  title          String           @db.VarChar(180)
  slug           String           @unique @db.VarChar(220)
  description    String
  department     String           @db.VarChar(140)
  experience     String?          @db.VarChar(120)
  location       String           @db.VarChar(160)
  employmentType EmploymentType
  salaryRange    String?          @db.VarChar(120)
  skills         Json
  status         JobStatus        @default(DRAFT)
  publishedAt    DateTime?
  applications   JobApplication[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  @@index([status])
  @@index([department])
  @@index([publishedAt])
  @@index([deletedAt])
  @@map("job_postings")
}

model Candidate {
  id           String           @id @default(uuid()) @db.Uuid
  firstName    String           @db.VarChar(120)
  lastName     String           @db.VarChar(120)
  email        String           @db.VarChar(180)
  phone        String?          @db.VarChar(40)
  linkedin     String?
  github       String?
  portfolio    String?
  experience   Decimal?         @db.Decimal(5, 2)
  skills       Json?
  applications JobApplication[]
  documents    Document[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?

  @@index([email])
  @@index([deletedAt])
  @@map("candidates")
}

model JobApplication {
  id          String           @id @default(uuid()) @db.Uuid
  jobId       String           @db.Uuid
  candidateId String           @db.Uuid
  job         JobPosting       @relation(fields: [jobId], references: [id], onDelete: Restrict)
  candidate   Candidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  resumeUrl   String?
  coverLetter String?
  stage       ApplicationStage @default(APPLIED)
  interviews  Interview[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  @@unique([jobId, candidateId])
  @@index([stage])
  @@index([createdAt])
  @@map("job_applications")
}

model Interview {
  id            String          @id @default(uuid()) @db.Uuid
  applicationId String          @db.Uuid
  interviewerId String          @db.Uuid
  application   JobApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  interviewer   Employee        @relation("InterviewInterviewer", fields: [interviewerId], references: [id], onDelete: Restrict)
  scheduledAt   DateTime
  durationMins  Int             @default(60)
  mode          String          @db.VarChar(80)
  meetingLink   String?
  status        InterviewStatus @default(SCHEDULED)
  rating        Int?
  feedback      String?
  remarks       String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  @@index([scheduledAt])
  @@index([interviewerId])
  @@index([status])
  @@map("interviews")
}

model Template {
  id           String    @id @default(uuid()) @db.Uuid
  name         String    @db.VarChar(160)
  key          String    @unique @db.VarChar(120)
  htmlContent  String
  cssContent   String?
  previewImage String?
  offerLetters OfferLetter[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@index([deletedAt])
  @@map("templates")
}

model OfferLetter {
  id           String    @id @default(uuid()) @db.Uuid
  candidateId  String?   @db.Uuid
  employeeId   String?   @db.Uuid
  templateId   String    @db.Uuid
  template     Template  @relation(fields: [templateId], references: [id], onDelete: Restrict)
  variables    Json
  generatedUrl String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@index([candidateId])
  @@index([employeeId])
  @@map("offer_letters")
}

model OnboardingWorkflow {
  id          String   @id @default(uuid()) @db.Uuid
  candidateId String?  @db.Uuid
  employeeId  String?  @db.Uuid
  status      String   @db.VarChar(80)
  currentStep Int      @default(1)
  steps       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([status])
  @@map("onboarding_workflows")
}

model Document {
  id           String          @id @default(uuid()) @db.Uuid
  provider     StorageProvider @default(CLOUDINARY)
  key          String
  url          String
  mimeType     String          @db.VarChar(120)
  sizeBytes    Int?
  uploadedById String?         @db.Uuid
  candidateId  String?         @db.Uuid
  candidate    Candidate?      @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  entityType   String?         @db.VarChar(80)
  entityId     String?         @db.Uuid
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?

  @@index([entityType, entityId])
  @@index([candidateId])
  @@map("documents")
}

model NotificationTemplate {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(120)
  channel   NotificationChannel
  subject   String?
  body      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([channel])
  @@map("notification_templates")
}

model Notification {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @db.Uuid
  channel   NotificationChannel
  title     String              @db.VarChar(180)
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([userId, readAt])
  @@map("notifications")
}

model NotificationPreference {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @db.Uuid
  channel   NotificationChannel
  eventKey  String              @db.VarChar(120)
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([userId, channel, eventKey])
  @@map("notification_preferences")
}

model ActivityLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @db.Uuid
  action      String   @db.VarChar(120)
  entityType  String   @db.VarChar(80)
  entityId    String?  @db.Uuid
  oldValues   Json?
  newValues   Json?
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @db.Uuid
  event       String   @db.VarChar(120)
  ipAddress   String?  @db.VarChar(80)
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([event])
  @@index([createdAt])
  @@map("audit_logs")
}
