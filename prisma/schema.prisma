generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(uuid()) @db.Uuid
  userId              String               @unique @db.VarChar(64)
  passwordHash        String
  status              UserStatus           @default(PASSWORD_RESET_REQUIRED)
  forcePasswordReset  Boolean              @default(true)
  failedLoginAttempts Int                  @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  employeeId          String?              @unique @db.Uuid
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  sessions            AuthSession[]
  passwordResets      PasswordResetToken[]
  roles               UserRole[]
  employee            Employee?            @relation(fields: [employeeId], references: [id])

  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id             String           @id @default(uuid()) @db.Uuid
  code           String           @unique @db.VarChar(80)
  name           String           @db.VarChar(120)
  description    String?
  isSystem       Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?
  hierarchyLevel Int              @default(100)
  permissions    RolePermission[]
  users          UserRole[]

  @@index([deletedAt])
  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique @db.VarChar(120)
  resource    String           @db.VarChar(80)
  action      String           @db.VarChar(80)
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  roles       RolePermission[]

  @@index([resource, action])
  @@index([deletedAt])
  @@map("permissions")
}

model UserRole {
  userId    String   @db.Uuid
  roleId    String   @db.Uuid
  createdAt DateTime @default(now())
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuthSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  refreshTokenHash String
  familyId         String    @db.Uuid
  replacedById     String?   @db.Uuid
  ipAddress        String?   @db.VarChar(80)
  userAgent        String?
  deviceInfo       Json?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Employee {
  id                      String                     @id @default(uuid()) @db.Uuid
  employeeId              String                     @unique @db.VarChar(64)
  firstName               String                     @db.VarChar(120)
  lastName                String                     @db.VarChar(120)
  email                   String                     @unique @db.VarChar(180)
  phone                   String?                    @db.VarChar(40)
  designation             String                     @db.VarChar(140)
  department              String                     @db.VarChar(140)
  joiningDate             DateTime
  employmentType          EmploymentType
  reportingManagerId      String?                    @db.Uuid
  status                  EmployeeStatus             @default(ACTIVE)
  profilePhoto            String?
  emergencyContact        Json?
  address                 Json?
  createdAt               DateTime                   @default(now())
  updatedAt               DateTime                   @updatedAt
  deletedAt               DateTime?
  attendanceRecords       AttendanceRecord[]
  regularizationRequests  AttendanceRegularization[]
  reviewedRegularizations AttendanceRegularization[] @relation("RegularizationReviewer")
  reportingManager        Employee?                  @relation("ReportingManager", fields: [reportingManagerId], references: [id])
  directReports           Employee[]                 @relation("ReportingManager")
  interviewAssignments    Interview[]                @relation("InterviewInterviewer")
  approvals               LeaveApproval[]            @relation("LeaveApprover")
  leaveBalances           LeaveBalance[]
  createdCalendarEvents   LeaveCalendarEvent[]       @relation("CalendarEventCreator")
  leaveRequests           LeaveRequest[]             @relation("LeaveRequester")
  user                    User?

  @@index([department])
  @@index([status])
  @@index([reportingManagerId])
  @@index([deletedAt])
  @@map("employees")
}

model AppConfig {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(120)
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("app_configs")
}

model AttendanceSetting {
  id           String    @id @default(uuid()) @db.Uuid
  officeStart  String    @db.VarChar(8)
  officeEnd    String    @db.VarChar(8)
  graceMinutes Int       @default(10)
  workingDays  Json
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@index([isActive])
  @@map("attendance_settings")
}

model AttendanceRegularization {
  id                String    @id @default(uuid()) @db.Uuid
  employeeId        String    @db.Uuid
  attendanceDate    DateTime
  requestedCheckIn  DateTime?
  requestedCheckOut DateTime?
  reason            String
  status            String    @db.VarChar(40)
  remarks           String?
  reviewedById      String?   @db.Uuid
  reviewedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewedBy        Employee? @relation("RegularizationReviewer", fields: [reviewedById], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([attendanceDate])
  @@index([reviewedById])
  @@map("attendance_regularizations")
}

model LeaveCalendarEvent {
  id          String    @id @default(uuid()) @db.Uuid
  title       String    @db.VarChar(180)
  date        DateTime
  type        String    @db.VarChar(80)
  description String?
  createdById String?   @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   Employee? @relation("CalendarEventCreator", fields: [createdById], references: [id])

  @@index([date])
  @@index([createdById])
  @@map("leave_calendar_events")
}

model OfficeLocation {
  id             String    @id @default(uuid()) @db.Uuid
  name           String    @db.VarChar(120)
  latitude       Decimal   @db.Decimal(10, 7)
  longitude      Decimal   @db.Decimal(10, 7)
  allowedRadiusM Int
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@index([isActive])
  @@map("office_locations")
}

model AttendanceRecord {
  id             String            @id @default(uuid()) @db.Uuid
  employeeId     String            @db.Uuid
  attendanceDate DateTime
  checkInAt      DateTime?
  checkOutAt     DateTime?
  workMinutes    Int               @default(0)
  breakMinutes   Int               @default(0)
  status         AttendanceStatus  @default(ABSENT)
  checkInMeta    Json?
  checkOutMeta   Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  breaks         AttendanceBreak[]
  employee       Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, attendanceDate])
  @@index([attendanceDate])
  @@index([status])
  @@map("attendance_records")
}

model AttendanceBreak {
  id                 String           @id @default(uuid()) @db.Uuid
  attendanceRecordId String           @db.Uuid
  startedAt          DateTime
  endedAt            DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  attendanceRecord   AttendanceRecord @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)

  @@index([attendanceRecordId])
  @@map("attendance_breaks")
}

model LeaveType {
  id          String         @id @default(uuid()) @db.Uuid
  name        String         @db.VarChar(120)
  code        String         @unique @db.VarChar(40)
  annualQuota Decimal        @db.Decimal(6, 2)
  isPaid      Boolean        @default(true)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?
  balances    LeaveBalance[]
  requests    LeaveRequest[]

  @@index([isActive])
  @@map("leave_types")
}

model LeaveBalance {
  id          String    @id @default(uuid()) @db.Uuid
  employeeId  String    @db.Uuid
  leaveTypeId String    @db.Uuid
  year        Int
  allocated   Decimal   @db.Decimal(6, 2)
  used        Decimal   @default(0) @db.Decimal(6, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveTypeId, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id          String             @id @default(uuid()) @db.Uuid
  employeeId  String             @db.Uuid
  leaveTypeId String             @db.Uuid
  startDate   DateTime
  endDate     DateTime
  days        Decimal            @db.Decimal(6, 2)
  reason      String?
  status      LeaveRequestStatus @default(PENDING_TEAM_LEAD)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?
  approvals   LeaveApproval[]
  employee    Employee           @relation("LeaveRequester", fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType   LeaveType          @relation(fields: [leaveTypeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

model LeaveApproval {
  id             String       @id @default(uuid()) @db.Uuid
  leaveRequestId String       @db.Uuid
  approverId     String       @db.Uuid
  level          Int
  decision       String       @db.VarChar(40)
  remarks        String?
  decidedAt      DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  approver       Employee     @relation("LeaveApprover", fields: [approverId], references: [id])
  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)

  @@index([leaveRequestId])
  @@index([approverId])
  @@map("leave_approvals")
}

model JobPosting {
  id             String           @id @default(uuid()) @db.Uuid
  title          String           @db.VarChar(180)
  slug           String           @unique @db.VarChar(220)
  description    String
  department     String           @db.VarChar(140)
  experience     String?          @db.VarChar(120)
  location       String           @db.VarChar(160)
  employmentType EmploymentType
  salaryRange    String?          @db.VarChar(120)
  skills         Json
  status         JobStatus        @default(DRAFT)
  publishedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?
  applications   JobApplication[]

  @@index([status])
  @@index([department])
  @@index([publishedAt])
  @@index([deletedAt])
  @@map("job_postings")
}

model Candidate {
  id           String           @id @default(uuid()) @db.Uuid
  firstName    String           @db.VarChar(120)
  lastName     String           @db.VarChar(120)
  email        String           @db.VarChar(180)
  phone        String?          @db.VarChar(40)
  linkedin     String?
  github       String?
  portfolio    String?
  experience   Decimal?         @db.Decimal(5, 2)
  skills       Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?
  documents    Document[]
  applications JobApplication[]

  @@index([email])
  @@index([deletedAt])
  @@map("candidates")
}

model JobApplication {
  id          String           @id @default(uuid()) @db.Uuid
  jobId       String           @db.Uuid
  candidateId String           @db.Uuid
  resumeUrl   String?
  coverLetter String?
  stage       ApplicationStage @default(APPLIED)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  notes       String?
  source      String?
  interviews  Interview[]
  candidate   Candidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job         JobPosting       @relation(fields: [jobId], references: [id])

  @@unique([jobId, candidateId])
  @@index([stage])
  @@index([createdAt])
  @@map("job_applications")
}

model Interview {
  id            String          @id @default(uuid()) @db.Uuid
  applicationId String          @db.Uuid
  interviewerId String          @db.Uuid
  scheduledAt   DateTime
  durationMins  Int             @default(60)
  mode          String          @db.VarChar(80)
  meetingLink   String?
  status        InterviewStatus @default(SCHEDULED)
  rating        Int?
  feedback      String?
  remarks       String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  notifiedAt    DateTime?
  application   JobApplication  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  interviewer   Employee        @relation("InterviewInterviewer", fields: [interviewerId], references: [id])

  @@index([scheduledAt])
  @@index([interviewerId])
  @@index([status])
  @@map("interviews")
}

model Template {
  id           String        @id @default(uuid()) @db.Uuid
  name         String        @db.VarChar(160)
  key          String        @unique @db.VarChar(120)
  htmlContent  String
  cssContent   String?
  previewImage String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  category     String?       @db.VarChar(80)
  isDefault    Boolean       @default(false)
  variables    String[]
  offerLetters OfferLetter[]

  @@index([isDefault])
  @@index([deletedAt])
  @@map("templates")
}

model OfferLetter {
  id           String    @id @default(uuid()) @db.Uuid
  templateId   String    @db.Uuid
  variables    Json
  generatedUrl String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  status       String    @default("DRAFT") @db.VarChar(40)
  template     Template  @relation(fields: [templateId], references: [id])

  @@index([createdAt])
  @@map("offer_letters")
}

model OnboardingWorkflow {
  id          String    @id @default(uuid()) @db.Uuid
  candidateId String?   @db.Uuid
  employeeId  String?   @db.Uuid
  status      String    @db.VarChar(80)
  currentStep Int       @default(1)
  steps       Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([status])
  @@map("onboarding_workflows")
}

model Document {
  id           String          @id @default(uuid()) @db.Uuid
  provider     StorageProvider @default(CLOUDINARY)
  key          String
  url          String
  mimeType     String          @db.VarChar(120)
  sizeBytes    Int?
  uploadedById String?         @db.Uuid
  candidateId  String?         @db.Uuid
  entityType   String?         @db.VarChar(80)
  entityId     String?         @db.Uuid
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  deletedAt    DateTime?
  candidate    Candidate?      @relation(fields: [candidateId], references: [id])

  @@index([entityType, entityId])
  @@index([candidateId])
  @@map("documents")
}

model NotificationTemplate {
  id        String              @id @default(uuid()) @db.Uuid
  key       String              @unique @db.VarChar(120)
  channel   NotificationChannel
  subject   String?
  body      String
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  deletedAt DateTime?

  @@index([channel])
  @@map("notification_templates")
}

model Notification {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @db.Uuid
  channel   NotificationChannel
  title     String              @db.VarChar(180)
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([userId, readAt])
  @@map("notifications")
}

model NotificationPreference {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @db.Uuid
  channel   NotificationChannel
  eventKey  String              @db.VarChar(120)
  enabled   Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([userId, channel, eventKey])
  @@map("notification_preferences")
}

model ActivityLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @db.Uuid
  action      String   @db.VarChar(120)
  entityType  String   @db.VarChar(80)
  entityId    String?  @db.Uuid
  oldValues   Json?
  newValues   Json?
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @db.Uuid
  event       String   @db.VarChar(120)
  ipAddress   String?  @db.VarChar(80)
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([event])
  @@index([createdAt])
  @@map("audit_logs")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
  PASSWORD_RESET_REQUIRED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_NOTICE
  TERMINATED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  CONSULTANT
}

enum AttendanceStatus {
  PRESENT
  LATE
  HALF_DAY
  ABSENT
}

enum LeaveRequestStatus {
  PENDING_TEAM_LEAD
  PENDING_HR
  APPROVED
  REJECTED
  CANCELLED
}

enum JobStatus {
  DRAFT
  PUBLISHED
  UNPUBLISHED
  CLOSED
}

enum ApplicationStage {
  APPLIED
  SCREENING
  INTERVIEW_SCHEDULED
  TECHNICAL_ROUND
  HR_ROUND
  SELECTED
  REJECTED
  OFFER_SENT
  JOINED
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
  FEEDBACK_PENDING
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum StorageProvider {
  CLOUDINARY
  S3
}
